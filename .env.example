# ============================================================
# PsicoGestión - Variables de entorno
# Copia este archivo como .env y completa los valores reales.
# En Vercel: configura estas variables en Settings > Environment Variables
# ============================================================

NODE_ENV=production
PORT=3000

# ── Base de datos (TiDB Cloud) ───────────────────────────────
DB_HOST=gateway01.XX-XXXX-X.prod.aws.tidbcloud.com
DB_PORT=4000
DB_USERNAME=XXXXXXXXXX.root
DB_PASSWORD=XXXXXXXXXXXXXXXX
DB_DATABASE=psicogestion_db

# SSL (TiDB siempre necesita SSL)
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false
# Ruta opcional al certificado CA (dejar vacío para usar el de TiDB Cloud por defecto)
# DB_SSL_CA_PATH=certs/tidb-ca.pem

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_seguro
JWT_EXPIRES_IN=24h

# ── Bcrypt ───────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── SMTP (Gmail) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM=tu_correo@gmail.com

# ── Frontend (Create React App) ──────────────────────────────
# En Vercel esta variable se configura también en Environment Variables
# con el dominio real que Vercel asigne al proyecto.
REACT_APP_API_URL=https://tu-proyecto.vercel.app

# ── Logs ─────────────────────────────────────────────────────
LOG_LEVEL=info
